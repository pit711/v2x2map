<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingBottom="32dp">

    <!-- Drag handle -->
    <View
        android:layout_width="36dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="14dp"
        android:background="@color/border"/>

    <!-- Title row: colour dot  +  type name  +  size -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:gravity="center_vertical"
        android:paddingBottom="10dp">

        <View
            android:id="@+id/detailDot"
            android:layout_width="14dp"
            android:layout_height="14dp"
            android:layout_marginEnd="10dp"
            android:background="@drawable/ic_status_dot"/>

        <TextView
            android:id="@+id/detailTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="@color/text"/>

        <TextView
            android:id="@+id/detailSize"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:textColor="@color/text_dim"
            android:fontFamily="monospace"/>
    </LinearLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/border"/>

    <!-- Scrollable body -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <LinearLayout
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="16dp">

            <!-- Metadata rows (monospace two-column text) -->
            <TextView
                android:id="@+id/detailMeta"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="12sp"
                android:lineSpacingMultiplier="1.5"
                android:textColor="@color/text"
                android:fontFamily="monospace"/>

            <!-- Hex dump header -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="HEX DUMP"
                android:textAllCaps="true"
                android:textSize="10sp"
                android:letterSpacing="0.12"
                android:textColor="@color/text_dim"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="6dp"/>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/border"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:id="@+id/detailHex"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textSize="11sp"
                android:lineSpacingMultiplier="1.4"
                android:textColor="@color/accent"
                android:fontFamily="monospace"/>

        </LinearLayout>
    </ScrollView>
</LinearLayout>
