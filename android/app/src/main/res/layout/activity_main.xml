<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar"
        android:layout_width="0dp"
        android:layout_height="?attr/actionBarSize"
        android:background="?attr/colorSurface"
        android:elevation="0dp"
        app:title="@string/app_name"
        app:titleTextAppearance="@style/TextAppearance.Material3.TitleLarge"
        app:menu="@menu/menu_main"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Connection button row — elevated surface, sits above the map -->
    <LinearLayout
        android:id="@+id/controls"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="10dp"
        android:paddingVertical="6dp"
        android:gravity="center_vertical"
        android:background="?attr/colorSurface"
        android:elevation="4dp"
        app:layout_constraintTop_toBottomOf="@id/toolbar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnConnect"
            style="@style/Widget.Material3.Button.TonalButton"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:layout_marginEnd="6dp"
            android:text="@string/connect"
            android:textSize="12sp"
            android:maxLines="1"
            android:ellipsize="end"
            app:cornerRadius="10dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnConnectBt"
            style="@style/Widget.Material3.Button.TonalButton"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:text="@string/connect_bt"
            android:textSize="12sp"
            android:maxLines="1"
            android:ellipsize="end"
            app:cornerRadius="10dp"/>

    </LinearLayout>

    <!-- Guideline — controls map/log split; changed programmatically to collapse log -->
    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/logSplit"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.70"/>

    <org.osmdroid.views.MapView
        android:id="@+id/map"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toBottomOf="@id/controls"
        app:layout_constraintBottom_toTopOf="@id/logHeader"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- Drive Mode view — replaces map when active -->
    <org.opentrafficmap.receiver.DriveView
        android:id="@+id/driveView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/controls"
        app:layout_constraintBottom_toTopOf="@id/logHeader"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- SPATEM traffic-light overlay — rounded pill, bottom-left of map -->
    <LinearLayout
        android:id="@+id/spatLight"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/bg_overlay_rounded"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        android:layout_marginTop="10dp"
        android:layout_marginStart="10dp"
        android:elevation="6dp"
        android:visibility="gone"
        app:layout_constraintTop_toTopOf="@id/map"
        app:layout_constraintStart_toStartOf="@id/map">
        <View android:id="@+id/lightRed"    android:layout_width="18dp" android:layout_height="18dp" android:background="@drawable/ic_status_dot"/>
        <View android:id="@+id/lightYellow" android:layout_width="18dp" android:layout_height="18dp" android:layout_marginStart="6dp" android:background="@drawable/ic_status_dot"/>
        <View android:id="@+id/lightGreen"  android:layout_width="18dp" android:layout_height="18dp" android:layout_marginStart="6dp" android:background="@drawable/ic_status_dot"/>
    </LinearLayout>

    <!-- Mini FAB: Drive Mode toggle — sits above fabOtmLive in the FAB column -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabDriveMode"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="4dp"
        android:contentDescription="@string/drive_mode_label"
        app:srcCompat="@drawable/ic_drive"
        app:fabSize="mini"
        app:layout_constraintEnd_toEndOf="@id/map"
        app:layout_constraintBottom_toTopOf="@id/fabOtmLive"/>

    <!-- Mini FAB: OTM live data toggle -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabOtmLive"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="4dp"
        android:contentDescription="@string/otm_live_label"
        app:srcCompat="@drawable/ic_live"
        app:fabSize="mini"
        app:layout_constraintEnd_toEndOf="@id/map"
        app:layout_constraintBottom_toTopOf="@id/fabCompass"/>

    <!-- Mini FAB: compass / bearing-up toggle -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabCompass"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="4dp"
        android:contentDescription="@string/compass_north_up"
        app:srcCompat="@drawable/ic_compass"
        app:fabSize="mini"
        app:layout_constraintEnd_toEndOf="@id/map"
        app:layout_constraintBottom_toTopOf="@id/fabLayers"/>

    <!-- Mini FAB: map layer picker -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabLayers"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="4dp"
        android:contentDescription="@string/map_layer_title"
        app:srcCompat="@drawable/ic_layers"
        app:fabSize="mini"
        app:layout_constraintEnd_toEndOf="@id/map"
        app:layout_constraintBottom_toTopOf="@id/fabLocate"/>

    <!-- Locate FAB -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabLocate"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="12dp"
        android:contentDescription="@string/locate"
        app:srcCompat="@drawable/ic_my_location"
        app:layout_constraintEnd_toEndOf="@id/map"
        app:layout_constraintBottom_toBottomOf="@id/map"/>

    <!-- Speed / bearing overlay — rounded pill, bottom-left of map -->
    <TextView
        android:id="@+id/speedOverlay"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_overlay_rounded"
        android:textColor="#FFFFFFFF"
        android:textSize="13sp"
        android:fontFamily="monospace"
        android:padding="7dp"
        android:paddingHorizontal="10dp"
        android:layout_marginStart="10dp"
        android:layout_marginBottom="10dp"
        android:elevation="6dp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="@id/map"
        app:layout_constraintStart_toStartOf="@id/map"/>

    <!-- Log header with packet stats and collapse button -->
    <LinearLayout
        android:id="@+id/logHeader"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="?attr/colorSurfaceContainer"
        android:elevation="3dp"
        android:clickable="true"
        android:focusable="true"
        app:layout_constraintTop_toTopOf="@id/logSplit"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:paddingStart="12dp"
            android:paddingTop="8dp"
            android:paddingBottom="8dp"
            android:text="@string/frames_log_header"
            android:textAllCaps="true"
            android:letterSpacing="0.08"
            android:textSize="10sp"
            android:textStyle="bold"
            android:alpha="0.75"/>

        <TextView
            android:id="@+id/logStats"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingEnd="6dp"
            android:textSize="10sp"
            android:fontFamily="monospace"
            android:alpha="0.65"
            tools:text="0 pkts · 0/min"/>

        <ImageView
            android:id="@+id/logCollapseBtn"
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:padding="8dp"
            android:contentDescription="@string/toggle_log"
            app:srcCompat="@drawable/ic_expand_more"/>
    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/log"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        app:layout_constraintTop_toBottomOf="@id/logHeader"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <TextView
        android:id="@+id/emptyLog"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:padding="16dp"
        android:gravity="center"
        android:text="@string/empty_log"
        android:textSize="12sp"
        android:alpha="0.45"
        app:layout_constraintTop_toTopOf="@id/log"
        app:layout_constraintBottom_toBottomOf="@id/log"
        app:layout_constraintStart_toStartOf="@id/log"
        app:layout_constraintEnd_toEndOf="@id/log"/>

</androidx.constraintlayout.widget.ConstraintLayout>
